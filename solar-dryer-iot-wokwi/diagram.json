{
  "version": 1,
  "author": "Mr Lachu",
  "editor": "wokwi",
  "parts": [
    {
      "type": "board-esp32-devkit-c-v4",
      "id": "esp",
      "top": 0,
      "left": 0,
      "attrs": {}
    },
    {
      "type": "wokwi-dht22",
      "id": "dht",
      "top": -80,
      "left": -160,
      "attrs": { "temperature": "28", "humidity": "65" }
    },
    {
      "type": "wokwi-potentiometer",
      "id": "pot",
      "top": 180,
      "left": -180,
      "attrs": { "value": "0.45" }
    },
    {
      "type": "wokwi-led",
      "id": "led_fan",
      "top": -100,
      "left": 200,
      "attrs": { "color": "green", "label": "FAN" }
    },
    {
      "type": "wokwi-resistor",
      "id": "res1",
      "top": -60,
      "left": 200,
      "attrs": { "value": "220" }
    }
  ],
  "connections": [
    ["esp:TX",  "$serialMonitor:RX", "", []],
    ["esp:RX",  "$serialMonitor:TX", "", []],

    ["esp:3V3", "dht:VCC",  "red",   []],
    ["esp:GND", "dht:GND",  "black", []],
    ["esp:4",   "dht:SDA",  "blue",  []],

    ["esp:3V3", "pot:VCC",  "red",   []],
    ["esp:GND", "pot:GND",  "black", []],
    ["esp:34",  "pot:SIG",  "green", []],

    ["esp:26",     "res1:1",       "green",  []],
    ["res1:2",     "led_fan:A",    "green",  []],
    ["esp:GND",    "led_fan:C",    "black",  []]
  ],
  "dependencies": {}
}